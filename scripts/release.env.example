# Copy to scripts/release.env and fill values.
# scripts/release.env is intentionally untracked.

# Required for notarization
DEV_ID_APP="Developer ID Application: YOUR NAME (TEAMID)"
AC_PROFILE="your-notarytool-keychain-profile"

# Optional app naming
APP_DISPLAY_NAME="Back Channel"
APP_EXECUTABLE_NAME="Backchannel"

# Optional output zip name from notarize_release.sh
# Defaults to <APP_DISPLAY_NAME-with-dashes>.zip
ZIP_NAME="Back-Channel.zip"

# Optional pinned tool binaries for deterministic builds
# YTDLP_BINARY="$HOME/.local/bin/yt-dlp"
# FFMPEG_BINARY="/opt/homebrew/bin/ffmpeg"
# FFPROBE_BINARY="/opt/homebrew/bin/ffprobe"
# DENO_BINARY="/opt/homebrew/bin/deno"

# Optional bundle/version metadata passed through to build
# APP_BUNDLE_ID="com.example.backchannel"
# APP_SHORT_VERSION="1.2.3"
# APP_BUILD_VERSION="123"
