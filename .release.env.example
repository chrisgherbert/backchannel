# Copy this file to .release.env and fill in real values.
# .release.env is gitignored.

# Required: Developer ID signing identity shown by:
# security find-identity -v -p codesigning
SIGNING_IDENTITY="Developer ID Application: Chris Herbert (Z9V2EC7ASL)"

# Required: Apple Developer Team ID
TEAM_ID="Z9V2EC7ASL"

# Required: notarytool keychain profile name (created with notarytool store-credentials)
NOTARY_KEYCHAIN_PROFILE="backchannel-notary"

# Required: path to standalone yt-dlp binary (Mach-O, not Python wrapper)
YTDLP_BINARY="$HOME/.local/bin/yt-dlp"

# Optional: explicit ffmpeg/ffprobe/deno binaries to bundle
# Note: deno is required for release builds.
# FFMPEG_BINARY="/opt/homebrew/bin/ffmpeg"
# FFPROBE_BINARY="/opt/homebrew/bin/ffprobe"
# DENO_BINARY="/opt/homebrew/bin/deno"

# Optional: versioning passed to package script
APP_SHORT_VERSION="1.0.0"
# APP_BUILD_VERSION="2026022701"

# Optional: output app path if you changed app name/location
APP_PATH="/Users/herbert/web/youtube-live-converter/dist/Back Channel.app"

# Optional: if 1, script will run notarytool store-credentials before submit.
STORE_NOTARY_CREDENTIALS=0
# Required only when STORE_NOTARY_CREDENTIALS=1
# APPLE_ID="you@example.com"
# APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
